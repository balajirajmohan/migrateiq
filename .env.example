# AWS Configuration
AWS_PROFILE=presidio-devops
AWS_REGION=us-east-1

# Source Database (MySQL)
SOURCE_DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
SOURCE_DB_PORT=3306
SOURCE_DB_NAME=migrateiq_source
SOURCE_DB_USER=migrateiq_admin
SOURCE_DB_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# Target Database (Aurora PostgreSQL)
TARGET_DB_HOST=your-aurora-endpoint.us-east-1.rds.amazonaws.com
TARGET_DB_PORT=5432
TARGET_DB_NAME=migrateiq_target
TARGET_DB_USER=migrateiq_admin
TARGET_DB_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# AWS Resources (populated after terraform apply)
S3_BUCKET_NAME=migrateiq-reports-853973692277
DYNAMODB_STATE_TABLE=migrateiq-migration-state
DYNAMODB_KB_TABLE=migrateiq-knowledge-base
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:853973692277:migrateiq-alerts

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_REGION=us-east-1
